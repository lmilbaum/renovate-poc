{
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "traefik:\\s*[\\s\\S]*?chart_version:\\s*(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "traefik",
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "distribution:\\s*[\\s\\S]*?name:\\s*rke2[\\s\\S]*?version:\\s*(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "rancher/rke2",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["helm"],
      "registryUrls": ["https://traefik.github.io/charts"]
    }
  ]
}
