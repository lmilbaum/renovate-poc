{
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "nginx:\\s*\\n\\s*chart_version:\\s*(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "traefik",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://helm.traefik.io/traefik"
    }
  ]
}

