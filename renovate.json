
{
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "nginx:\\s*\\n\\s*chart_version:\\s*(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "bitnamicharts/nginx",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "registry-1.docker.io"
    }
  ]
}
