{
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "nginx:\\s*\\n\\s*chart_version:\\s*(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "nginx-ingress",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://helm.nginx.com/stable"
    }
  ]
}

